{
  "name": "@ecommerce/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "npx tsx src/db/seed.ts",
    "db:reset": "prisma migrate reset --force && npx tsx src/db/seed.ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@apollo/server": "^4.11.0",
    "@prisma/client": "^5.18.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dataloader": "^2.2.3",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "graphql": "^16.9.0",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.5.4",
    "nodemon": "^3.1.4",
    "prisma": "^5.18.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  }
}
